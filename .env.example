# ---------------------------------------------------------------------------
# OpenRouter (OpenAI-compatible API) - get a key at https://openrouter.ai/keys
# ---------------------------------------------------------------------------
OPENROUTER_API_KEY=sk-or-your-key-here
# OpenRouter's OpenAI-compatible base URL. Change only if you proxy the
# request through another service.
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# App identity sent in the HTTP-Referer / X-Title headers.
APP_URL=http://localhost:8501
APP_NAME=Podcast Q&A Bot

# ---------------------------------------------------------------------------
# Data source
# ---------------------------------------------------------------------------
# YouTube URL of the podcast episode to ingest.
YOUTUBE_URL=https://www.youtube.com/watch?v=Rni7Fz7208c

# ---------------------------------------------------------------------------
# Models
# ---------------------------------------------------------------------------
# Whisper model size: tiny | base | small | medium | large
WHISPER_MODEL=base

# Sentence-Transformers model for embeddings.
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# LLM used to draft the final answer.
# Default is a free OpenRouter model. See https://openrouter.ai/models
# (filter by ":free") for the full list. Other good free options:
#   - openai/gpt-oss-20b:free
#   - openai/gpt-oss-120b:free
#   - meta-llama/llama-3.3-70b-instruct:free
#   - qwen/qwen3-next-80b-a3b-instruct:free
#   - z-ai/glm-4.5-air:free
LLM_MODEL=openai/gpt-oss-20b:free
LLM_TEMPERATURE=0

# ---------------------------------------------------------------------------
# Retrieval
# ---------------------------------------------------------------------------
# Number of chunks retrieved per question.
TOP_K=4

# Soft cap on chunk size (in characters) when building the index.
CHUNK_MAX_CHARS=800
